{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "General profile for both students and admins",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "Student": {
      "title": "Enrolled Student",
      "description": "Details of a student enrolled in the center",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "fatherName": { "type": "string" },
        "course": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "course", "isActive", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Daily attendance for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent"] },
        "markedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "date", "status", "markedBy", "timestamp"]
    },
    "Application": {
      "title": "Course Application",
      "description": "New student application for training",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "fatherName": { "type": "string" },
        "course": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "course", "email", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Enrolled students"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Daily attendance logs"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Course applications"
    },
    "/admins/{userId}": {
      "schema": { "type": "object", "properties": { "userId": { "type": "string" } } },
      "description": "Admin marker collection"
    }
  }
}
